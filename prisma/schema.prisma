generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Room {
  id        Int       @id @default(autoincrement())
  name      String
  building  String
  capacity  Int
  type      String
  amenities String
  bookings  Booking[]
}

model Booking {
  id        Int      @id @default(autoincrement())
  roomId    Int
  date      String
  startTime String
  endTime   String
  purpose   String
  room      Room     @relation(fields: [roomId], references: [id])
}
